{
  "name": "@cad/adapter-layer",
  "version": "0.1.0",
  "private": true,
  "description": "BSV Blockchain Adapter Layer for CAD Legacy Systems",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
