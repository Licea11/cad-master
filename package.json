{
  "name": "bsv-cad-system",
  "version": "1.0.0",
  "description": "Computer-Aided Dispatch system on BSV blockchain",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "bsv",
    "blockchain",
    "cad",
    "dispatch",
    "scrypt",
    "emergency"
